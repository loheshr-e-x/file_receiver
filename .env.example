# Example environment variables for Campus Print Service
# Copy this file to .env and fill in the real values locally (do NOT commit .env)

# Path to Google service account JSON file (optional - absolute or relative)
GOOGLE_CREDENTIALS_FILE=./credentials.json

# Cloudinary (if you decide to re-enable uploads)
CLOUDINARY_CLOUD_NAME=
CLOUDINARY_API_KEY=
CLOUDINARY_API_SECRET=

# Other secrets you may use
# EXAMPLE_API_TOKEN=
